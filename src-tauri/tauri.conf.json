{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitExodus",
  "version": "0.1.0",
  "identifier": "com.gitexodus.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GitExodus",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "copyright": "Copyright © 2026 GitExodus",
    "deb": {
      "depends": [
        "libwebkit2gtk-4.0-37",
        "librsvg2-common"
      ]
    },
    "dmg": {
      "background": null,
      "windowPosition": {
        "x": 400,
        "y": 200
      },
      "windowSize": {
        "width": 540,
        "height": 380
      },
      "appPath": null,
      "linkPath": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}